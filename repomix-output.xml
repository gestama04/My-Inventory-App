                        source={{ uri: `data:image/jpeg;base64,${item.photo}` }}
                        style={styles.itemThumbnail}
                      />
                    ) : (
                      <View style={styles.categoryIconContainer}>
                        <MaterialCommunityIcons
                          name={getCategoryIcon(item.category)}
