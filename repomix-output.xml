        <Text style={[styles.longPressHint, currentTheme === "dark" ? styles.darkTextSecondary : styles.lightTextSecondary]}>
          Toque num produto para ver os seus detalhes. Toque longo para mais opções.
        </Text>
      </View>
    </KeyboardAvoidingView>
  );
}

