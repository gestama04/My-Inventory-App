  const cancelEditing = useCallback(() => {
    setIsEditing(false);
  }, []);

  const cancelEditingPhoto = useCallback(() => {
    setIsEditingPhoto(false);
  }, []);

  // Carrega o item quando o componente é montado
useEffect(() => {
