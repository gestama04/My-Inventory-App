          />
        ) : (
          <View style={styles.iconBox}>
            <MaterialCommunityIcons
              name="pill"
              size={22}
              color="#7dd3fc"
            />
          </View>
        )}

        <View style={{ flex: 1 }}>
          <Text style={styles.name}>
            {item.supplement?.name ?? 'Suplemento'}
          </Text>

          <Text style={styles.meta}>
            {String(item.reminder_time).slice(0, 5)} ·{' '}
