                      )}

                      {!!metaText && <Text style={styles.meta}>{metaText}</Text>}
                    </View>

                    <Ionicons name="chevron-forward" size={22} color="#94a3b8" />
                  </TouchableOpacity>
                )
              }}
            />
          )}

          <AlertComponent />
        </View>
      </LinearGradient>
    </>
  )
