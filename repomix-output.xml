      </View>

      <Ionicons
  name="chevron-forward"
  size={22}
  color={highlighted ? '#bae6fd' : '#64748b'}
/>
    </TouchableOpacity>
  )
}
function Confetti() {
  const pieces = Array.from({ length: 24 })

  return (
    <View pointerEvents="none" style={styles.confettiLayer}>
      {pieces.map((_, index) => (
        <ConfettiPiece key={index} index={index} />
      ))}
    </View>
