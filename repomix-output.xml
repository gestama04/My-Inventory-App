        </View>

        <View style={[styles.checkBox, !item.taken && styles.missedBox]}>
          <Ionicons
            name={item.taken ? 'checkmark' : 'close'}
            size={20}
            color={item.taken ? '#052e16' : 'white'}
          />
        </View>
      </View>
    ))}
  </View>
))
          )}
        </ScrollView>
        <AlertComponent />
      </LinearGradient>
    </>
  )
}

