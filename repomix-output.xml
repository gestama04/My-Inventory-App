    const numValue = parseInt(cleanedText);
   
    // Se for um número válido, use-o; caso contrário, mantenha o valor atual
    if (!isNaN(numValue) && numValue >= 0) {
      setQuantity(cleanedText);
    } else if (cleanedText === '') {
