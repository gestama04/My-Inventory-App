            },
            {
              text: "Cancelar",
              style: "cancel",
              onPress: () => {}
            }
          ]
        );
        return;
      }
    }
    
    // If has permission, open scanner in specified mode
    setScanMode(mode);
    setIsScanning(true);
  };
  

