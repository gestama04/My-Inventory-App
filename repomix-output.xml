</View>
    </View>
  </View>

  <WeeklyStatusWidget days={weekDays} />
</View>
        <View style={styles.sectionHeader}>
          <View>
            <Text style={styles.sectionTitle}>Hoje</Text>
            <Text style={styles.todayStatus}>
